# HiveSight API (must be running)
HIVESIGHT_BASE_URL=http://localhost:8766

# LLM - groq (free) or openai
# Get Groq key at https://console.groq.com (keys start with gsk_)
# Or use same key as HiveSight's ai.groq.api-key
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_actual_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Or for OpenAI:
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini
