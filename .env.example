# Chargebee API Configuration
# Get these from: Chargebee Dashboard > Settings > Configure Chargebee > API Keys
# Use a SANDBOX site for testing: https://your-site-test.chargebee.com

CHARGEBEE_SITE=your-site-test
CHARGEBEE_API_KEY=test_xxxxxxxxxxxxxxxx

# Optional: Enable Ramps feature (request at app.chargebee.com/request_access/subscription-ramps)
# Subscription Ramps must be enabled for full HiveSight functionality
